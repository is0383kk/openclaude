{
  "env": {
    // Add environment variables here. These will be available to the agent when it runs.
  },
  "permissions": {
    "allow": [
      "Task",
      "Glob",
      "Read",
      "Grep",
      "Write",
      "Bash",
      "Edit",
      "WebFetch",
      "WebSearch",
      "ExitPlanMode",
      "Skill",
      "SlashCommand",
      "mcp__awslabs_aws-documentation-mcp-server",
      "mcp__serena",
      "mcp__filesystem",
      "mcp__playwright"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm:*)",
      "Bash(rm -rf:*)",
      "Bash(git push:*)",
      "Bash(git commit:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Bash(git push --force:*)",
      "Bash(pip install:*)",
      "Bash(choco install:*)",
      "Bash(Set-ExecutionPolicy:*)",
      "Bash(docker rm:*)",
      "Bash(docker rmi:*)",
      "Read(.env.*)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Read(**/*token*)",
      "Read(**/*key*)",
      "Read(**/*password*)",
      "Read(**/*secret*)",
      "Read(**/.ssh/**)",
      "Write(.env*)",
      "Write(**/secrets/**)",
      "Write(**/*.exe)",
      "Write(**/*.dll)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(nc:*)",
      "Bash(npm uninstall:*)",
      "Bash(npm remove:*)",
      "Bash(psql:*)",
      "Bash(mysql:*)",
      "Bash(mongod:*)",
      "mcp__supabase__execute_sql"
    ],
    "defaultMode": "acceptEdits"
  },
  "model": "us.anthropic.claude-sonnet-4-6"
}
